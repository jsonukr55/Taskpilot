rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ---------------------------------------------------------
    function signedIn() {
      return request.auth != null;
    }
    function groupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }
    function isMember(groupId) {
      return signedIn() && request.auth.uid in groupData(groupId).memberIds;
    }
    // Guarded by isMember so roles[uid] is always present when reached.
    function canEditGroup(groupId) {
      return isMember(groupId)
        && groupData(groupId).roles[request.auth.uid] in ['owner', 'editor'];
    }
    // The group owner == the team "manager" for the daily report.
    function isManager(groupId) {
      return isMember(groupId) && groupData(groupId).ownerId == request.auth.uid;
    }
    function dailyReport(reportId) {
      return get(/databases/$(database)/documents/dailyReports/$(reportId)).data;
    }

    // ---- Users: only own profile ----------------------------------------
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // ---- Categories: user-isolated --------------------------------------
    match /categories/{categoryId} {
      allow read, write: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ---- Schedules: user-isolated ---------------------------------------
    match /schedules/{scheduleId} {
      allow read, write: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ---- Insights: user-scoped, written by Cloud Functions --------------
    match /insights/{insightId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ---- Tasks: personal (userId) OR shared with a group ----------------
    // The 'groupId' existence guard keeps pre-existing personal tasks
    // (which have no groupId field) working exactly as before.
    match /tasks/{taskId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (('groupId' in resource.data) && resource.data.groupId != null
          && isMember(resource.data.groupId)) ||
        (('assigneeIds' in resource.data)
          && request.auth.uid in resource.data.assigneeIds)
      );
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && (
          !('groupId' in request.resource.data) || request.resource.data.groupId == null
          || canEditGroup(request.resource.data.groupId)
        );
      // Owner and group editors may fully edit. An assignee may update the task
      // (e.g. mark progress / complete) but not delete someone else's task.
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (('groupId' in resource.data) && resource.data.groupId != null
          && canEditGroup(resource.data.groupId)) ||
        (('assigneeIds' in resource.data)
          && request.auth.uid in resource.data.assigneeIds)
      );
      allow delete: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (('groupId' in resource.data) && resource.data.groupId != null
          && canEditGroup(resource.data.groupId))
      );
    }

    // ---- Personal notes: owner-scoped (top-level) -----------------------
    match /notes/{noteId} {
      allow read, write: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;

      match /comments/{commentId} {
        allow read, write, create: if signedIn()
          && get(/databases/$(database)/documents/notes/$(noteId)).data.ownerId == request.auth.uid;
      }
    }

    // ---- Groups: membership-based ---------------------------------------
    match /groups/{groupId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      // Owner manages name/members/roles. (Joins happen server-side via the
      // joinGroup Cloud Function, since a non-owner can't self-add here.)
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      // Notes: members read; editors/owner write.
      match /notes/{noteId} {
        allow read: if isMember(groupId);
        allow create, update, delete: if canEditGroup(groupId);

        // Comments: any member (incl. viewers) may add & anchor to a block;
        // authors and the group owner may edit/resolve/delete.
        match /comments/{commentId} {
          allow read: if isMember(groupId);
          allow create: if isMember(groupId)
            && request.resource.data.authorId == request.auth.uid;
          allow update, delete: if signedIn() && (
            resource.data.authorId == request.auth.uid ||
            groupData(groupId).ownerId == request.auth.uid
          );
        }
      }
    }

    // ---- Working calendar: global, read-only from the client ------------
    // Everyone reads the mandatory-holiday config; the app also ships a code
    // default, so an absent doc is fine. Edited out-of-band (console / admin
    // tooling) until an in-app manager editor lands.
    match /settings/{docId} {
      allow read:  if signedIn();
      allow write: if false;
    }

    // ---- Daily reports: one per (team, working-day) ---------------------
    // Parent doc = metadata + lock. Any member may lazily create it (so their
    // entry can attach); only the manager updates it (lock, order).
    match /dailyReports/{reportId} {
      allow read:   if signedIn() && isMember(resource.data.groupId);
      allow create: if signedIn()
        && isMember(request.resource.data.groupId)
        && request.resource.data.status == 'draft';
      allow update, delete: if signedIn() && isManager(resource.data.groupId);

      // Per-member entry. Decision #7: a member writes ONLY their own entry
      // (doc id == uid); the manager may write anyone's. No writes once locked
      // (manager included — lock is final).
      match /entries/{uid} {
        allow read: if signedIn() && isMember(dailyReport(reportId).groupId);
        allow create, update: if signedIn()
          && dailyReport(reportId).status != 'locked'
          && (request.auth.uid == uid || isManager(dailyReport(reportId).groupId));
        allow delete: if signedIn() && isManager(dailyReport(reportId).groupId);
      }
    }

    // ---- Invites: doc id IS the secret token ----------------------------
    // get(): anyone signed-in can preview a link they were given.
    // list(): only editors of that group (prevents token enumeration).
    match /invites/{token} {
      allow get:    if signedIn();
      allow list:   if signedIn() && canEditGroup(resource.data.groupId);
      allow create: if signedIn() && canEditGroup(request.resource.data.groupId);
      allow update, delete: if signedIn() && canEditGroup(resource.data.groupId);
    }
  }
}
